<?xml version="1.0" encoding="UTF-8"?>
<!-- Representatieve template (POC). Echte definitie komt uit X-Works wiz-vltmpl00-getocc. -->
<vragenlijsttemplate type="individuele-inkomenstoeslag" titel="Individuele inkomenstoeslag" administration="opmr">
  <pagina volgorde="1" naam="Inkomen">
    <vraag id="langdurigLaagInkomen" label="Heeft u 3 jaar of langer een laag inkomen?" type="keuze" verplicht="true">
      <optie>Ja</optie>
      <optie>Nee</optie>
    </vraag>
    <vraag id="maandinkomen" label="Netto maandinkomen (€)" type="bedrag" verplicht="true"/>
    <vraag id="uitkering" label="Ontvangt u een uitkering?" type="keuze" verplicht="true">
      <optie>Bijstand</optie>
      <optie>WW</optie>
      <optie>Geen</optie>
      <optie>Anders</optie>
    </vraag>
    <vraag id="uitkeringAnders" label="Toelichting uitkering" type="tekst" verplicht="true"
           zichtbaarAls="uitkering==Anders"/>
  </pagina>
  <pagina volgorde="2" naam="Vooruitzicht">
    <vraag id="zichtOpInkomen" label="Heeft u zicht op inkomensverbetering?" type="keuze" verplicht="true">
      <optie>Ja</optie>
      <optie>Nee</optie>
    </vraag>
    <vraag id="toelichting" label="Toelichting" type="tekst" verplicht="false"/>
  </pagina>
</vragenlijsttemplate>
